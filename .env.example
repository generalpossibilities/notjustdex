# NotJustDex environment configuration
# This app is fully decentralized — no Go services required.
# Chain + IPFS are the only infrastructure.

# Chat relay URLs (comma-separated, optional)
# Anyone can run a relay: dart run bin/server.dart
CHAT_RELAY_URLS=ws://localhost:8585

# IPFS gateway URLs (comma-separated, optional)
# Default: ipfs.io, cloudflare-ipfs.com, dweb.link
IPFS_GATEWAYS=

# Acki Nacki chain RPC endpoints (comma-separated, optional)
AN_RPC_ENDPOINTS=
